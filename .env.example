# Telegram
TELEGRAM_BOT_TOKEN=123456:your-bot-token-from-BotFather

# Anthropic (for AI-drafted messages)
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-5

# Brevo (transactional email — https://app.brevo.com)
BREVO_API_KEY=xkeysib-your-key
SENDER_EMAIL=you@yourdomain.com
SENDER_NAME=Campaign Pilot

# Optional: restrict bot to your own Telegram user id(s), comma separated.
# Leave empty to allow anyone who finds the bot to use it.
ALLOWED_USER_IDS=
